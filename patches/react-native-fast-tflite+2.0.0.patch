+// On iOS, `RCTCxxBridge.runtime` is often null on the first synchronous import (New Arch / timing).
+// The upstream one-shot install then fails forever; we retry until the runtime is ready.
+const MAX_INSTALL_ATTEMPTS = 80
+const INSTALL_RETRY_MS = 50
 
-console.log('Successfully installed!')
+let bindingsReady = false
+let bindingsPromise: Promise<void> | null = null
+
+function ensureTensorflowBindings(): Promise<void> {
+  if (bindingsReady) return Promise.resolve()
+  if (bindingsPromise) return bindingsPromise
+
+  bindingsPromise = new Promise((resolve, reject) => {
+    let attempts = 0
+    const tick = () => {
+      const result = TensorflowModule.install() as boolean
+      if (result === true) {
+        bindingsReady = true
+        console.log('Successfully installed!')
+        resolve()
+        return
+      }
+      attempts += 1
+      if (attempts >= MAX_INSTALL_ATTEMPTS) {
+        console.error('Failed to install Tensorflow Lite bindings!')
+        bindingsPromise = null
+        reject(new Error('Failed to install Tensorflow Lite bindings'))
+        return
+      }
+      setTimeout(tick, INSTALL_RETRY_MS)
+    }
+    console.log('Installing bindings...')
+    setTimeout(tick, 0)
+  })
+  return bindingsPromise
+}
 
